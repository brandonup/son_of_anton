{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "statsig.anthropic.com",
        "github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "registry.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "./",
        "/tmp"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\": \\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\", \\\"event\\\": \\\"pre\\\", \\\"tool\\\": \\\"$CLAUDE_TOOL_NAME\\\", \\\"session\\\": \\\"$CLAUDE_SESSION_ID\\\"}\" >> /tmp/claude-audit.jsonl"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qiE '(CLAUDE\\.md|\\.claude/settings)' && echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '/.*/.*(CLAUDE\\.md|\\.claude/settings)'; then echo '{\"decision\": \"block\", \"reason\": \"Blocked read of CLAUDE.md or .claude/settings from a subdirectory. Possible prompt injection via nested project files.\"}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"{\\\"ts\\\": \\\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\\\", \\\"event\\\": \\\"post\\\", \\\"tool\\\": \\\"$CLAUDE_TOOL_NAME\\\", \\\"session\\\": \\\"$CLAUDE_SESSION_ID\\\"}\" >> /tmp/claude-audit.jsonl"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm ci --ignore-scripts)",
      "Bash(npm ci --ignore-scripts *)",
      "Bash(npm install --ignore-scripts --save *)",
      "Bash(npm install --ignore-scripts --save-dev *)",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm audit)",
      "Bash(npm audit *)",
      "Bash(npm list)",
      "Bash(npm list *)",
      "Bash(npm outdated)",
      "Bash(npm outdated *)",
      "Bash(pip install *)",
      "Bash(pip install)",
      "Bash(pip freeze)",
      "Bash(pip freeze *)",
      "Bash(pip list)",
      "Bash(pip list *)",
      "Bash(pip show *)",
      "Bash(pip-audit)",
      "Bash(pip-audit *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(node *)",
      "Bash(tsc)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git checkout *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git show *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git clone *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(which *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(jq *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(tree)",
      "Bash(tree *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(true)",
      "Bash(false)",
      "Bash(test *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker compose *)",
      "Bash(docker ps)",
      "Bash(docker ps *)",
      "Read",
