    ],
    "deny": [
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(bash -c *curl*)",
      "Bash(sh -c *curl*)",
      "Bash(bash -c *wget*)",
      "Bash(sh -c *wget*)",
      "Bash(curl * > *.sh*)",
      "Bash(wget * > *.sh*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git branch -D *)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(npx *)",
      "Bash(docker push *)",
      "Bash(docker rmi *)",
      "Bash(apt-get *)",
      "Bash(apt install *)",
      "Bash(brew *)",
      "Bash(launchctl *)",
      "Bash(crontab *)",
      "Bash(systemctl *)",
      "Bash(printenv)",
      "Bash(printenv *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(cat *.env*)",
      "Bash(cat *secrets*)",
      "Bash(cat ~/.ssh*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.kube*)",
      "Bash(*~/.ssh*)",
      "Bash(*~/.aws*)",
      "Bash(*~/.config*)",
      "Bash(*~/.kube*)",
      "Bash(*~/.gnupg*)",
      "Bash(*~/.netrc*)",
      "Bash(*~/.npmrc*)",
      "Bash(*~/.pypirc*)",
      "Bash(*~/Library/Keychains*)",
      "Bash(*~/.docker/config*)",
      "Bash(*/.ssh/*)",
      "Bash(*/.aws/*)",
      "Bash(*/.config/*)",
      "Bash(*/.kube/*)",
      "Bash(*/.gnupg/*)",
      "Bash(npm ci)",
      "Bash(npm ci *)",
      "Bash(npm install --save *)",
      "Bash(npm install --save-dev *)",
      "Bash(npm install)",
      "Bash(npm install http:*)",
      "Bash(npm install https:*)",
      "Bash(npm install git+*)",
      "Bash(npm install github:*)",
      "Bash(pip install http:*)",
      "Bash(pip install https:*)",
      "Bash(pip install git+*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env.local)",
      "Read(.env.local)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Read(**/config/.env)",
      "Read(./secrets/**)",
      "Read(secrets/**)",
      "Read(./**/secrets*)",
      "Read(**/*secrets*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/Library/Keychains/**)",
      "Read(~/Library/Application Support/Google/Chrome/**)",
      "Read(~/Library/Application Support/Firefox/**)",
      "Read(~/Library/Cookies/**)",
      "Edit(~/**)",
      "Write(~/**)",
      "WebFetch(*)",
      "Read(**/node_modules/**/CLAUDE.md)",
      "Read(**/node_modules/**/.claude/**)",
      "Read(projects/**/code/**/CLAUDE.md)",
      "Read(projects/**/code/**/.claude/**)",
      "mcp__*__write_file(*)",
      "mcp__*__delete_file(*)",
      "mcp__*__execute(*)",
      "mcp__*__delete_comment(*)",
      "mcp__*__delete_attachment(*)"
    ]
  }
}
